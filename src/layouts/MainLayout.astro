---
import '../styles/global.css';
import Sidebar from '../components/ui/Sidebar.tsx';
import { getCollection } from 'astro:content';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  currentId?: string;
  showSidebar?: boolean; // Nueva prop para controlar la visibilidad
}

const { title, description = "Diario de Aprendizaje Interactivo de Japonés", currentId, showSidebar = false } = Astro.props;

// Fetch lessons for the Sidebar (only if enabled)
let sortedLessons: any[] = [];
if (showSidebar) {
  const lessons = await getCollection('lessons');
  sortedLessons = lessons
    .filter(lesson => !lesson.data.isDraft)
    .sort((a, b) => a.data.chapterNumber - b.data.chapterNumber);
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | IchiBit</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet">
    <ClientRouter />
  </head>
  <body class="bg-[#FAFAFA] dark:bg-[#18181B] text-zinc-900 dark:text-zinc-100 h-screen font-sans flex flex-col overflow-hidden">
    
    <header class="flex-none bg-white/80 dark:bg-zinc-900/80 backdrop-blur border-b border-zinc-200 dark:border-zinc-800">
      <nav class="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between">
        <div class="flex items-center gap-4">
          <a href="/" class="text-xl font-bold text-[#F43F5E] flex items-center gap-2 group">
            <span>一</span>
            <span class="text-zinc-900 dark:text-zinc-100 group-hover:text-[#F43F5E] transition-colors">IchiBit</span>
          </a>
        </div>

        <div class="flex items-center gap-4">
          {/* Botón Menú Móvil (Solo visible en < lg) */}
          {showSidebar && (
            <button id="mobile-toggle" class="lg:hidden p-2 rounded-lg bg-zinc-100 dark:bg-zinc-800 hover:bg-zinc-200 dark:hover:bg-zinc-700 transition-colors" aria-label="Abrir navegación">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
            </button>
          )}
          <a href="https://github.com/Steven-Mendez/IchiBit" target="_blank" class="text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors" aria-label="GitHub Repository">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
          </a>
        </div>
      </nav>
    </header>


    <div id="layout-container" class={`flex-1 flex flex-col min-h-0 max-w-7xl mx-auto px-4 w-full transition-all duration-300 relative ${showSidebar ? 'lg:flex-row' : ''}`}>

      <!-- Navegación Lateral Escritorio (Minimalist Rail Style) -->
      {showSidebar && (
        <aside 
          id="desktop-sidebar" 
          class="hidden lg:block relative flex-none h-[calc(100%-2rem)] transition-all duration-300 ease-in-out group/sidebar mt-8"
          style="width: 288px; margin-right: 3rem;"
        >
          <div id="sidebar-content" class="h-full overflow-y-auto border-r border-zinc-100 dark:border-zinc-800/50 pr-6 transition-opacity duration-300">
            <Sidebar client:idle lessons={sortedLessons} currentId={currentId} />
          </div>

          {/* Toggle Handle (Anchored to the rail edge) */}
          <button 
            id="sidebar-toggle" 
            class="hidden lg:flex absolute -right-3 top-1/2 -translate-y-1/2 z-40 w-6 h-12 bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-xl items-center justify-center hover:bg-zinc-50 dark:hover:bg-zinc-800 transition-all shadow-sm group"
            aria-label="Alternar barra lateral"
          >
            <svg id="icon-sidebar" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 text-zinc-400 group-hover:text-[#F43F5E]"><path d="m15 18-6-6 6-6"/></svg>
          </button>
        </aside>
      )}


      <!-- ... Menú Móvil Overlay (sin cambios) ... -->
      {showSidebar && (
        <div id="mobile-sidebar" class="fixed inset-0 z-50 transform -translate-x-full transition-transform duration-300 lg:hidden">
          <div id="sidebar-overlay" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
          <div class="absolute left-0 top-0 bottom-0 w-80 bg-white dark:bg-zinc-900 p-6 shadow-2xl overflow-y-auto">
            <div class="flex justify-between items-center mb-6 pb-4 border-b border-zinc-200 dark:border-zinc-800">
              <a href="/" class="text-xl font-bold text-[#F43F5E] flex items-center gap-2 group">
                <span>一</span>
                <span class="text-zinc-900 dark:text-zinc-100 group-hover:text-[#F43F5E] transition-colors">IchiBit</span>
              </a>
              <button id="menu-close" class="p-2 rounded-lg bg-zinc-100 dark:bg-zinc-800 hover:bg-zinc-200 dark:hover:bg-zinc-700 transition-colors text-zinc-500">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
              </button>
            </div>
            <Sidebar client:idle lessons={sortedLessons} currentId={currentId} />
          </div>
        </div>
      )}

      <!-- Contenido Principal -->
      <main class={`flex-1 flex flex-col min-h-0 py-3 md:py-4 w-full overflow-x-hidden ${!showSidebar ? 'max-w-4xl mx-auto' : 'w-full'}`}>
        <slot />
      </main>
    </div>

    <footer class="flex-none border-t border-zinc-200 dark:border-zinc-800 py-4 bg-white/50 dark:bg-zinc-900/50">
      <div class="max-w-7xl mx-auto px-4 text-center text-zinc-500 text-xs">
        <p>© {new Date().getFullYear()} IchiBit - Aprendamos japonés juntos.</p>
      </div>
    </footer>

    {showSidebar && (
      <script>
        const toggle = document.getElementById('sidebar-toggle');
        const mobileToggle = document.getElementById('mobile-toggle');
        const close = document.getElementById('menu-close');
        const mobileSidebar = document.getElementById('mobile-sidebar');
        const overlay = document.getElementById('sidebar-overlay');
        const desktopSidebar = document.getElementById('desktop-sidebar');
        const sidebarContent = document.getElementById('sidebar-content');
        const iconSidebar = document.getElementById('icon-sidebar');

        const lgBreakpoint = window.matchMedia('(min-width: 1024px)');

        function init() {
          if (lgBreakpoint.matches) {
            const isCollapsed = localStorage.getItem('sidebar-collapsed') === 'true';
            applyCollapsedState(isCollapsed);
          } else {
            document.body.classList.remove('overflow-hidden');
            mobileSidebar?.classList.add('-translate-x-full');
          }
        }

        function applyCollapsedState(collapsed: boolean) {
          if (desktopSidebar && sidebarContent) {
            if (collapsed) {
              desktopSidebar.style.width = '0px';
              desktopSidebar.style.marginRight = '1.5rem';
              sidebarContent.style.opacity = '0';
              sidebarContent.style.pointerEvents = 'none';
              iconSidebar?.classList.add('rotate-180');
            } else {
              desktopSidebar.style.width = '288px';
              desktopSidebar.style.marginRight = '3rem';
              sidebarContent.style.opacity = '1';
              sidebarContent.style.pointerEvents = 'auto';
              iconSidebar?.classList.remove('rotate-180');
            }
          }
        }

        function toggleSidebar() {
          const isCollapsed = desktopSidebar?.style.width === '0px';
          const nextState = !isCollapsed;
          applyCollapsedState(nextState);
          localStorage.setItem('sidebar-collapsed', String(nextState));
        }

        function toggleMobile() {
          mobileSidebar?.classList.toggle('-translate-x-full');
          document.body.classList.toggle('overflow-hidden');
        }

        toggle?.addEventListener('click', toggleSidebar);
        mobileToggle?.addEventListener('click', toggleMobile);
        close?.addEventListener('click', toggleMobile);
        overlay?.addEventListener('click', toggleMobile);
        lgBreakpoint.addEventListener('change', init);
        init();
      </script>
    )}
  </body>
</html>
